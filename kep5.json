{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Globális UFO észlelések eloszlása",
    "subtitle": "Összes regisztrált eset az adatbázisban: 70 662 észlelés",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "subtitleColor": "#4a5568",
    "anchor": "start"
  },
  "width": 570,
  "height": 400,
  "projection": {
    "type": "equalEarth"
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#e2e8f0", "stroke": "#ffffff"}
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "values": [
                {"Country": "United States of America", "Sightings": 65114},
                {"Country": "Canada", "Sightings": 3000},
                {"Country": "United Kingdom", "Sightings": 1905},
                {"Country": "Australia", "Sightings": 538},
                {"Country": "Germany", "Sightings": 105}
              ]
            },
            "key": "Country",
            "fields": ["Sightings"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "#ffffff"},
      "encoding": {
        "color": {
          "field": "Sightings",
          "type": "quantitative",
          "title": "Észlelések száma",
          "scale": {
            "type": "log",
            "scheme": "reds"
          }
        },
        "config": {
    "title": {"color": "#ffffff", "subtitleColor": "#cccccc"},
    "axis": {
      "domainColor": "#ffffff",
      "gridColor": "rgba(255, 255, 255, 0.1)",
      "labelColor": "#ffffff",
      "tickColor": "#ffffff",
      "titleColor": "#ffffff"
    },
    "legend": {
      "labelColor": "#ffffff",
      "titleColor": "#ffffff"
    }
  },
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "Ország"},
          {"field": "Sightings", "type": "quantitative", "title": "Észlelések száma"}
        ]
      }
    }
  ]
}